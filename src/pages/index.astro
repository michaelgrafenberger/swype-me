  #final-cta { scroll-margin-top: 72px; }
</style>

<style>
  /* ── Creator Video Wall ── */
  .vwall {
    position: absolute; top: 0; bottom: 0; width: 290px;
    overflow: hidden; z-index: 1; pointer-events: none;
    mask-image: linear-gradient(to bottom,
      transparent 0%, rgba(0,0,0,.5) 8%, black 18%, black 62%, rgba(0,0,0,.25) 82%, transparent 100%);
