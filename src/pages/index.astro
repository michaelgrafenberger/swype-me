  .cta-sub { font-size: 18px; line-height: 1.6; color: rgba(255,255,255,0.55); max-width: 520px; margin: 0 auto 48px; }
  .cta-aurora {
    position: absolute; border-radius: 50%; pointer-events: none; filter: blur(80px);
    animation: aurora-drift 24s ease-in-out infinite;
  }
  .btn-cta-white {
    display: inline-flex; align-items: center; gap: 8px;
    height: 52px; padding: 0 28px; border-radius: 999px;
    background: white; color: #09090B; font-size: 15px; font-weight: 600;
