  .vwall-l .vwall-track { animation: vscroll-up 54s linear infinite; align-items: flex-start; }
  .vwall-r .vwall-track { animation: vscroll-down 64s linear infinite; align-items: flex-end; }

  @keyframes vscroll-up {
    0%   { transform: translateY(0); }
