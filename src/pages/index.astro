  }
  .cvcard-bar-fill { height: 100%; background: white; border-radius: 2px; }

  /* Edge fades – thin solid at very edge, quickly opens to let creators show */
  .hero-fade-l, .hero-fade-r {
    position: absolute; top: 0; bottom: 0; width: 360px; z-index: 2; pointer-events: none;
  }
  .hero-fade-l { left: 0;
    background: linear-gradient(to right,
      var(--bg) 0%,
      rgba(250,250,248,.88) 7%,
      rgba(250,250,248,.52) 18%,
      rgba(250,250,248,.22) 32%,
      rgba(250,250,248,.06) 52%,
      transparent 72%); }
  .hero-fade-r { right: 0;
    background: linear-gradient(to left,
      var(--bg) 0%,
      rgba(250,250,248,.88) 7%,
      rgba(250,250,248,.52) 18%,
      rgba(250,250,248,.22) 32%,
      rgba(250,250,248,.06) 52%,
      transparent 72%); }

  /* Ensure hero text floats above the walls */
  #hero > .container { position: relative; z-index: 3; }

  /* CTA glow */
  .cta-glow-wrap { position: relative; display: inline-flex; align-items: center; gap: 12px; flex-wrap: wrap; justify-content: center; }
  .cta-glow-wrap::before {
    content: '';
    position: absolute;
    width: 320px; height: 80px;
    background: radial-gradient(ellipse at 38% 50%, rgba(77,141,255,0.28) 0%, rgba(165,107,255,0.16) 45%, transparent 72%);
    filter: blur(24px);
    top: 50%; left: 50%; transform: translate(-50%, -50%);
    pointer-events: none; z-index: 0; animation: aurora-drift 8s ease-in-out infinite;
  }
  .cta-glow-wrap > * { position: relative; z-index: 1; }

  /* Hide walls below 1140px */
  @media (max-width: 1140px) {
    .vwall, .hero-fade-l, .hero-fade-r { display: none; }
  }
