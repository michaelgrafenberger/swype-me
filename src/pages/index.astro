  }
  .btn-cta-ghost:hover { background: rgba(255,255,255,0.07); border-color: rgba(255,255,255,0.35); color: white; }

  /* ── Footer ── */
  footer { padding-block: 56px; border-top: 1px solid var(--border); }
  .footer-logo { font-size: 14px; font-weight: 800; letter-spacing: -0.04em; color: var(--text-primary); }
